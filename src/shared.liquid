{% comment %} ============ PARTIALS ============ {% endcomment %}

{% comment %} weather_icon: code (symbol id), size (px) {% endcomment %}
{% template weather_icon %}
<svg class="image" width="{{ size }}" height="{{ size }}"><use href="#{{ code }}" /></svg>
{% endtemplate %}

{% comment %} temp: c (celsius value), unit ("c"/"f"), with_unit (show C/F) {% endcomment %}
{% template temp %}{% if unit == "f" %}{{ c | times: 1.8 | plus: 32 | round }}{% else %}{{ c | round }}{% endif %}&deg;{% if with_unit %}{{ unit | upcase }}{% endif %}{% endtemplate %}

{% comment %} now_block: vertical current-conditions (full + halves). params: station, today, today_name, icon_size, temp_size, desc_class, temp_inline, range_class, range_small_class, day_label_class {% endcomment %}
{% template now_block %}
<div class="content flex flex--col flex--center-x flex--center-y text--center gap--small">
  <span class="{{ day_label_class | default: 'label label--base' }}">Vandaag ({{ today_name }})</span>
  {% assign now_code = station.fullIconUrl | split: "/" | last | split: "." | first | slice: 0 | upcase %}
  {% if temp_inline %}
    <div class="flex flex--row flex--center-y my--2 lg:my--4">
      {% render "weather_icon", code: now_code, size: icon_size %}
      <span class="value {{ temp_size }} value--tnums">{% render "temp", c: station.temperature, unit: unit, with_unit: true %}</span>
    </div>
  {% else %}
    {% render "weather_icon", code: now_code, size: icon_size %}
    <span class="value {{ temp_size }} value--tnums">{% render "temp", c: station.temperature, unit: unit, with_unit: true %}</span>
  {% endif %}
  <span class="value {{ range_class | default: 'value--base text--gray-35' }} value--tnums">{% render "temp", c: today.maxtemperature, unit: unit %} / <span class="{{ range_small_class | default: 'value--small' }}">{% render "temp", c: today.mintemperature, unit: unit %}</span></span>
  <span class="hidden lg:inline">
    <span class="{{ desc_class }}">{{ station.weatherdescription }}</span>
    <span class="label label--underline">Wind {{ station.winddirection }} · {{ station.windspeed }} m/s</span>
  </span>
</div>
{% endtemplate %}

{% comment %} now_bar: horizontal current-conditions (quarter). params: station, today, icon_size, temp_size {% endcomment %}
{% template now_bar %}
<div class="content flex flex--col gap--small">
  <div class="flex flex--row flex--center-y gap--medium">
    {% assign now_code = station.fullIconUrl | split: "/" | last | split: "." | first | slice: 0 | upcase %}
    {% render "weather_icon", code: now_code, size: icon_size %}
    <div class="flex flex--col gap--xsmall">
      <span class="value {{ temp_size }} value--tnums">{% render "temp", c: station.temperature, unit: unit, with_unit: true %}</span>
      <span class="value value--xsmall text--gray-35 value--tnums">{% render "temp", c: today.maxtemperature, unit: unit %} / <span class="value--xxsmall">{% render "temp", c: today.mintemperature, unit: unit %}</span></span>
    </div>
  </div>
  <div class="hidden lg:flex flex--col gap--xsmall">
    <span class="label label--small">{{ station.weatherdescription }}</span>
    <span class="label label--small">Wind {{ station.winddirection }} · {{ station.windspeed }} m/s</span>
  </div>
</div>
{% endtemplate %}

{% comment %} forecast_card: one day. params: day, dagen, icon_size; optional bg, pad, dir_class, group_class, label_class, val_class, val_small_class, fill {% endcomment %}
{% template forecast_card %}
{% assign d_idx = day.day | date: "%w" | plus: 0 %}
{% assign d_code = day.fullIconUrl | split: "/" | last | split: "." | first | upcase %}
<div class="bg--{{ bg | default: 'gray-70' }} rounded {{ pad | default: 'px--2 py--3' }}{% if fill %} h--full{% endif %}">
  <div class="content flex flex--col {{ dir_class | default: 'lg:portrait:flex--row lg:portrait:flex--row.flex--between' }} flex--center-x flex--center-y text--center gap--small{% if fill %} h--full{% endif %}">
    <span class="{{ label_class | default: 'label lg:portrait:label--large' }}">{{ dagen[d_idx] }}</span>
    <div class="flex {{ group_class | default: 'flex--col lg:portrait:flex--row lg:portrait:gap--small' }} flex--center-x flex--center-y gap--small">
      <span class="{{ icon_vis | default: 'hidden lg:inline' }}">
        {% render "weather_icon", code: d_code, size: icon_size %}
      </span>
      <span class="value {{ val_class | default: 'value--small' }} value--tnums">{% render "temp", c: day.maxtemperature, unit: unit %} <span class="{{ icon_vis | default: 'hidden lg:inline' }}">/ <span class="{{ val_small_class | default: 'text--gray-35' }}">{% render "temp", c: day.mintemperature, unit: unit %}</span></span></span>
    </div>
  </div>
</div>
{% endtemplate %}

{% comment %} text_block: heading + body paragraph. params: heading, body {% endcomment %}
{% template text_block %}
<div class="content flex flex--col flex--left gap--small">
  <span class="label label--large lg:label--xlarge mb--2">{{ heading }}</span>
  <p class="text--gray-35 text--base lg:text--large">{{ body }}</p>
</div>
{% endtemplate %}

